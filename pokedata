#!/usr/bin/env python3

import sqlite3
import sys
from pathlib import Path

# =============================================================================
# Static schema — seeded from PokéAPI, never written to during gameplay
# =============================================================================

STATIC_SCHEMA = """
-- ---------------------------------------------------------------------------
-- pokemon
-- Base species data for gen 1 (ids 1-151).
-- Stats are base values, not instance values.
-- Types map to the PokemonType enum in C.
-- ---------------------------------------------------------------------------
CREATE TABLE IF NOT EXISTS pokemon (
    id              INTEGER PRIMARY KEY,  -- pokedex number 1-151
    name            TEXT    NOT NULL UNIQUE,
    base_hp         INTEGER NOT NULL CHECK(base_hp > 0),
    base_attack     INTEGER NOT NULL CHECK(base_attack > 0),
    base_defense    INTEGER NOT NULL CHECK(base_defense > 0),
    base_sp_attack  INTEGER NOT NULL CHECK(base_sp_attack > 0),
    base_sp_defense INTEGER NOT NULL CHECK(base_sp_defense > 0),
    base_speed      INTEGER NOT NULL CHECK(base_speed > 0),
    type1           TEXT    NOT NULL,
    type2           TEXT    DEFAULT NULL  -- NULL if single-type
);

-- ---------------------------------------------------------------------------
-- moves
-- Full move list for gen 1 (union of red-blue + yellow).
-- Damage class maps to MoveDamageClass enum in C.
-- Status effect maps to StatusEffect enum in C, NULL if none.
-- ---------------------------------------------------------------------------
CREATE TABLE IF NOT EXISTS moves (
    id              INTEGER PRIMARY KEY,  -- pokeapi move id
    name            TEXT    NOT NULL UNIQUE,
    type            TEXT    NOT NULL,
    damage_class    TEXT    NOT NULL CHECK(damage_class IN ('physical', 'special', 'status')),
    power           INTEGER DEFAULT NULL CHECK(power IS NULL OR power > 0),
    accuracy        INTEGER DEFAULT NULL CHECK(accuracy IS NULL OR (accuracy > 0 AND accuracy <= 100)),
    pp              INTEGER NOT NULL CHECK(pp > 0),
    priority        INTEGER NOT NULL DEFAULT 0,
    status_effect   TEXT    DEFAULT NULL CHECK(
                        status_effect IS NULL OR
                        status_effect IN ('burn', 'paralysis', 'poison', 'sleep', 'freeze')
                    ),
    status_chance   INTEGER DEFAULT NULL CHECK(
                        status_chance IS NULL OR
                        (status_chance > 0 AND status_chance <= 100)
                    )
);

-- ---------------------------------------------------------------------------
-- pokemon_moves (learnset)
-- Which moves each species can learn, how, and at what level.
-- Composite PK allows same move via both level_up AND tm (e.g. Thunderbolt).
-- learn_level is NULL unless learn_method = 'level_up'.
-- ---------------------------------------------------------------------------
CREATE TABLE IF NOT EXISTS pokemon_moves (
    pokemon_id      INTEGER NOT NULL REFERENCES pokemon(id),
    move_id         INTEGER NOT NULL REFERENCES moves(id),
    learn_method    TEXT    NOT NULL CHECK(learn_method IN ('level_up', 'tm', 'hm')),
    learn_level     INTEGER DEFAULT NULL CHECK(
                        (learn_method = 'level_up' AND learn_level IS NOT NULL AND learn_level >= 0) OR
                        (learn_method != 'level_up' AND learn_level IS NULL)
                    ),
    PRIMARY KEY (pokemon_id, move_id, learn_method)
);

-- ---------------------------------------------------------------------------
-- morphdex (evolution table)
-- Tracks what each pokemon evolves into and at what level.
-- Stone/trade evolutions are hardcoded to a reasonable level.
-- evolves_into_id is a soft reference — no FK so we can seed in any order.
-- evolution_method: what originally triggered it (informational only for C).
-- For Eevee's branching evolutions, there are 3 rows with the same pokemon_id.
-- ---------------------------------------------------------------------------
CREATE TABLE IF NOT EXISTS morphdex (
    id                  INTEGER PRIMARY KEY AUTOINCREMENT,
    pokemon_id          INTEGER NOT NULL REFERENCES pokemon(id),
    evolves_into_id     INTEGER NOT NULL,  -- references pokemon(id), no FK for seed order
    level_required      INTEGER NOT NULL CHECK(level_required > 0),
    evolution_method    TEXT    NOT NULL CHECK(
                            evolution_method IN ('level_up', 'stone', 'trade')
                        ),
    -- for branching evolutions (Eevee), priority determines which form is chosen.
    -- 1 = first choice. if you want random, handle it in C using this as a weight.
    branch_priority     INTEGER NOT NULL DEFAULT 1 CHECK(branch_priority > 0)
);

CREATE INDEX IF NOT EXISTS idx_morphdex_pokemon ON morphdex(pokemon_id);
"""

# =============================================================================
# Instance schema — mutable game state, loaded into memory at battle start,
# flushed back in a single transaction after battle ends
# =============================================================================

INSTANCE_SCHEMA = """
-- ---------------------------------------------------------------------------
-- battles
-- One row per battle session.
-- outcome is NULL while the battle is in progress.
-- ---------------------------------------------------------------------------
CREATE TABLE IF NOT EXISTS battles (
    id          INTEGER PRIMARY KEY AUTOINCREMENT,
    created_at  INTEGER NOT NULL,  -- unix timestamp
    ended_at    INTEGER DEFAULT NULL,
    outcome     TEXT    DEFAULT NULL CHECK(outcome IS NULL OR outcome IN ('win', 'loss', 'flee'))
);

-- ---------------------------------------------------------------------------
-- parties
-- One row per side per battle.
-- is_player = 1 for the player, 0 for the enemy.
-- Enemy piggybacks off this same table — same structure, just a flag.
-- ---------------------------------------------------------------------------
CREATE TABLE IF NOT EXISTS parties (
    id          INTEGER PRIMARY KEY AUTOINCREMENT,
    battle_id   INTEGER NOT NULL REFERENCES battles(id),
    is_player   INTEGER NOT NULL CHECK(is_player IN (0, 1))
);

CREATE INDEX IF NOT EXISTS idx_parties_battle ON parties(battle_id);

-- ---------------------------------------------------------------------------
-- party_pokemon
-- An instance of a pokemon belonging to a party.
-- Links to static pokemon(id) for base data.
-- max_hp is computed on spawn and cached — avoids recalculating in C.
-- status is the current non-volatile status condition.
-- is_active: only one per party should be 1 at a time (enforced in C).
-- ---------------------------------------------------------------------------
CREATE TABLE IF NOT EXISTS party_pokemon (
    id          INTEGER PRIMARY KEY AUTOINCREMENT,
    party_id    INTEGER NOT NULL REFERENCES parties(id),
    pokemon_id  INTEGER NOT NULL,           -- soft ref to static pokemon(id)
    nickname    TEXT    DEFAULT NULL,        -- NULL means use species name in C
    level       INTEGER NOT NULL CHECK(level BETWEEN 1 AND 100),
    exp         INTEGER NOT NULL DEFAULT 0 CHECK(exp >= 0),
    current_hp  INTEGER NOT NULL CHECK(current_hp >= 0),
    max_hp      INTEGER NOT NULL CHECK(max_hp > 0),
    status      TEXT    DEFAULT NULL CHECK(
                    status IS NULL OR
                    status IN ('burn', 'paralysis', 'poison', 'sleep', 'freeze')
                ),
    is_active   INTEGER NOT NULL DEFAULT 0 CHECK(is_active IN (0, 1))
);

CREATE INDEX IF NOT EXISTS idx_party_pokemon_party ON party_pokemon(party_id);

-- ---------------------------------------------------------------------------
-- party_pokemon_moves
-- The 4 moves this pokemon instance currently knows, with live PP.
-- slot enforces the 4-move cap and ordering (1-4).
-- current_pp is what gets decremented in memory and flushed after battle.
-- move_id is a soft ref to static moves(id).
-- ---------------------------------------------------------------------------
CREATE TABLE IF NOT EXISTS party_pokemon_moves (
    id                  INTEGER PRIMARY KEY AUTOINCREMENT,
    party_pokemon_id    INTEGER NOT NULL REFERENCES party_pokemon(id),
    move_id             INTEGER NOT NULL,   -- soft ref to static moves(id)
    current_pp          INTEGER NOT NULL CHECK(current_pp >= 0),
    slot                INTEGER NOT NULL CHECK(slot BETWEEN 1 AND 4),
    UNIQUE(party_pokemon_id, slot)          -- no duplicate slots per pokemon
);

CREATE INDEX IF NOT EXISTS idx_ppm_party_pokemon ON party_pokemon_moves(party_pokemon_id);
"""


def seed_smoke_test(conn: sqlite3.Connection) -> None:
    """
    Insert one row into every static table and one full battle chain
    into every instance table, then roll back. Proves constraints work
    before you run the real seeder.
    """
    cur = conn.cursor()
    try:
        # --- static ---
        cur.execute("""
            INSERT INTO pokemon VALUES (
                25, 'pikachu', 35, 55, 40, 50, 50, 90, 'electric', NULL
            )
        """)
        cur.execute("""
            INSERT INTO moves VALUES (
                85, 'thunderbolt', 'electric', 'special',
                90, 100, 15, 0, 'paralysis', 10
            )
        """)
        cur.execute("""
            INSERT INTO pokemon_moves VALUES (25, 85, 'level_up', 26)
        """)
        cur.execute("""
            INSERT INTO pokemon_moves VALUES (25, 85, 'tm', NULL)
        """)
        cur.execute("""
            INSERT INTO morphdex
                (pokemon_id, evolves_into_id, level_required, evolution_method, branch_priority)
            VALUES (25, 26, 36, 'stone', 1)
        """)

        # --- instance ---
        import time

        cur.execute("INSERT INTO battles (created_at) VALUES (?)", (int(time.time()),))
        battle_id = cur.lastrowid

        cur.execute(
            "INSERT INTO parties (battle_id, is_player) VALUES (?, 1)", (battle_id,)
        )
        party_id = cur.lastrowid

        cur.execute(
            """
            INSERT INTO party_pokemon
                (party_id, pokemon_id, level, exp, current_hp, max_hp, is_active)
            VALUES (?, 25, 15, 1200, 44, 44, 1)
        """,
            (party_id,),
        )
        pp_id = cur.lastrowid

        cur.execute(
            """
            INSERT INTO party_pokemon_moves
                (party_pokemon_id, move_id, current_pp, slot)
            VALUES (?, 85, 15, 1)
        """,
            (pp_id,),
        )

        print("  smoke test: all inserts OK")

    finally:
        conn.rollback()  # always roll back — this is just a test
        print("  smoke test: rolled back (no data written)")


# =============================================================================
# Main
# =============================================================================


def main():
    db_path = Path("pokedata.db")
    print(f"[pokedata] target: {db_path.resolve()}")

    # setup sqlite3 db
    conn = sqlite3.connect(str(db_path))
    conn.execute("PRAGMA foreign_keys = ON")
    conn.execute("PRAGMA journal_mode = WAL")  # better concurrent read perf
    conn.execute("PRAGMA synchronous = NORMAL")  # safe but faster than FULL
    conn.row_factory = sqlite3.Row

    # drop all tables
    tables = [
        # instance first (FK dependents)
        "party_pokemon_moves",
        "party_pokemon",
        "parties",
        "battles",
        # static
        "morphdex",
        "pokemon_moves",
        "moves",
        "pokemon",
    ]
    cur = conn.cursor()
    for table in tables:
        cur.execute(f"DROP TABLE IF EXISTS {table}")
        print(f"  dropped: {table}")
    conn.commit()

    # create all tables
    print("[pokedata] creating schemas...")
    cur = conn.cursor()
    cur.executescript(STATIC_SCHEMA)
    cur.executescript(INSTANCE_SCHEMA)
    conn.commit()

    # verify schema
    print("[pokedata] verifying schemas...")
    expected = {
        "pokemon",
        "moves",
        "pokemon_moves",
        "morphdex",
        "battles",
        "parties",
        "party_pokemon",
        "party_pokemon_moves",
    }
    cur = conn.cursor()
    cur.execute("SELECT name FROM sqlite_master WHERE type='table'")
    found = {row["name"] for row in cur.fetchall()}
    missing = expected - found
    if missing:
        print(f"[ERROR] missing tables after creation: {missing}", file=sys.stderr)
        sys.exit(1)
    print(f"  verified {len(found)} tables: {', '.join(sorted(found))}")

    seed_smoke_test(conn)

    conn.close()
    print("[pokedata] done.")


if __name__ == "__main__":
    main()
